#!/bin/bash
# SPDX-FileCopyrightText: 2025-2026 Vitaliy Elin <daydve@smbit.pro>
# SPDX-License-Identifier: GPL-2.0-or-later
# Build the Unity Launcher QML plugin for a specific architecture
# Usage: ./build [arch]
# If arch is not provided, it uses `uname -m`

ARCH=$1
if [ -z "$ARCH" ]; then
    ARCH=$(uname -m)
fi

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
BUILD_DIR="$SCRIPT_DIR/../build-$ARCH"
DEST_DIR="$SCRIPT_DIR/../package/contents/ui/unity/bin/$ARCH"

echo "Building for architecture: $ARCH"

mkdir -p "$BUILD_DIR" "$DEST_DIR"
cmake -S "$SCRIPT_DIR" -B "$BUILD_DIR" -DCMAKE_BUILD_TYPE=Release
cmake --build "$BUILD_DIR" -j$(nproc)
cp "$BUILD_DIR/libfancytasksng_unityplugin.so" "$DEST_DIR/"

# Create qmldir for this architecture
cat <<EOF > "$DEST_DIR/qmldir"
# SPDX-License-Identifier: GPL-2.0-or-later
plugin fancytasksng_unityplugin
EOF

# Remove legacy plugin if it exists in the root unity directory
rm -f "$SCRIPT_DIR/../package/contents/ui/unity/libfancytasksng_unityplugin.so"
rm -f "$SCRIPT_DIR/../package/contents/ui/unity/qmldir"

echo "Unity plugin for $ARCH built and copied to $DEST_DIR"

