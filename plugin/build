# Build the Unity Launcher QML plugin and copy it into the plasmoid package
SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
BUILD_DIR="$SCRIPT_DIR/../build"
DEST_DIR="$SCRIPT_DIR/../package/contents/ui/unity"

mkdir -p "$BUILD_DIR" "$DEST_DIR"
cmake -S "$SCRIPT_DIR" -B "$BUILD_DIR" -DCMAKE_BUILD_TYPE=Release
cmake --build "$BUILD_DIR" -j$(nproc)
cp "$BUILD_DIR/libfancytasksng_unityplugin.so" "$DEST_DIR/"
echo "Unity plugin built and copied to $DEST_DIR"
